  "preparacion": [
    {
      "componente": "Crust",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Preheat oven to 475°F (245°C). Place a large pan filled with 1/2 inch (1.5 cm) of water in oven.",
          "temp_c": 245,
          "duracion_min": null,
          "notas_tecnicas": "Water bath for even baking."
        },
        {
          "orden": 2,
          "descripcion": "Mix graham cracker crumbs and cinnamon; add melted butter. Press crust onto bottom and 2/3 of the way up the sides of a 9-inch springform pan. Freeze 5 minutes.",
