          "duracion_min": 5,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Filling",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Use an electric mixer to mix cream cheese, sugar, sour cream and vanilla. Blend until smooth and creamy. Slowly add eggs, one at a time. Beat just until incorporated.",
          "temp_c": null,
          "duracion_min": 10,
          "notas_tecnicas": "Do not overmix — causes cracking."
        },
        {
          "orden": 2,
          "descripcion": "Pour filling into crust. Carefully place cheesecake into preheated water bath. Bake for 12 minutes at 475°F (245°C). Reduce temperature to 350°F (175°C) and bake 50-60 minutes.",
          "temp_c": 175,
          "duracion_min": 65,
          "notas_tecnicas": "Two-temperature method ensures proper rise and creamy texture."
