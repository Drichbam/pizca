  "preparacion": [
    {
      "componente": "Principal",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "lunes, 5 de enero de 2015",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Crème pâtissière",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Dans une casserole à fond épais, mélanger la maïzena avec la moitié du sucre puis verser le lait en tournant avec un fouet.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Fendre la gousse de vanille et gratter l'intérieur avec un petit couteau. Mettre les gousses et les graines dans la casserole et porter à ébullition tout en mélangeant en continu.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Dans une seconde casserole, fouetter le jaune d'oeuf avec le sucre restant. Y verser en mince filet le contenu de la première casserole en continuant de mélanger avec le fouet.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 4,
          "descripcion": "Porter la crème à ébullition et la retirer du feu aussitôt après le premier bouillon.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 5,
          "descripcion": "Enlever les gousses de vanille puis plonger la casserole de crème dans un récipient rempli de glaçons.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 6,
          "descripcion": "Lorsque la crème a refroidi et atteint environ 50°C, incorporer le beurre en tournant vivement avec le fouet et réserver au frais.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 7,
          "descripcion": "Si vous souhaitez éviter la peliculle qui se forme sur la crème, il vous suffit juste de poser dessus un film alimentaire lorsque la crème est encore chaude.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Crème d'amande",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Mélanger le sucre glace, la poudre d'amande et la maïzena et les tamiser.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Mettre le beurre dans un saladier et le travailler avec une spatule afin qu'il s'assouplisse.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Ajouter ensuite le mélange précédent puis l'oeuf sans cesser de tourner avec la spatule. Verser ensuite le rhum et la crème pâtissière.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Montage",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Préchauffer le four à 180°C (th. 6).",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Poser le premier disque de pâte bien froid sur une feuille de papier sulfurisée ou en silicone.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Chiquer la galette. A l'aide d'un pinceau, mouiller tout le tour de la pâte puis poser le deuxième disque de pâte en appuyant légèrement sur les bords pour bien sceller les 2 pâtes.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 4,
          "descripcion": "Mettre au froid 5-10min puis retourner la galette pour la dorer et décorer plus facilement",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 5,
          "descripcion": "A l'aide d'un pinceau, étaler un peu de jaune d'oeuf sur le dessus de la galette. Remettre au froid 5-10min. remettre une couche. Surtout bien étaler pour éviter les flaques. Remettre au froid.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 6,
          "descripcion": "Faire cuire environ 35-45 mn à 180°C (th. 6). La galette est cuite quand le dessous est cuit de manière homogène",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 7,
          "descripcion": "déguster tiède: 150°C pendant 15min",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    }
  ],
  "notas": [
    "Répartir la crème d'amande en faisant attention à laisser 2-3 cm sur le bord de la pâte pour la \"soudure\", pour chiquer la galette",
    "Vous pouvez faire des motifs sur la galette à l'aide d'un couteau en faisant attention de ne pas couper la pâte."
