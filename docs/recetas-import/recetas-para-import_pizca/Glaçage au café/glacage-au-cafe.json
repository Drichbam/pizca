        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Hacher le chocolat au couteau scie."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Faire bouillir la crème et la verser dessus en 3 fois, mélanger comme une ganache."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Ajouter le sirop à 30°B, l’essence de café et le glucose dans le nappage."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Verser le mélange dans la ganache et mixer quelques secondes."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Faire chauffer l’eau avec le sucre jusqu’à dissolution complète."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Ajouter ensuite la pectine NH, porter à ébullition 2 minutes, filtrer et mettre en pot."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Lors de l’utilisation, prélever la quantité voulue et faire fondre à feu très doux."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Ce nappage peut très bien se congeler."
        },
        {
          "cantidad": 430.0,
          "unidad": "g",
          "ingrediente": "d’eau"
        },
        {
          "cantidad": 570.0,
          "unidad": "g",
          "ingrediente": "sucre"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Faire chauffer dans une casserole l’eau et le sucre,"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "S’assurer que le sucre est bien dissous. Laisser refroidir."
        }
      ]
    }
