    {
      "nombre": "Préparation",
      "ingredientes": [
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Préchauffez votre four à 200° (thermostat 6)"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Dans un saladier, versez le yaourt"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Ajoutez par dessus 2 pots de sucre, et 3 pots de farine"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Ajoutez le pot d'amande en poudre, c'est ce qui rendra votre gâteau moelleux !"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Ajoutez le pot d'huile"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Cassez les 3 oeufs et ajoutez-les"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Ajoutez le demi sachet de levure, et le sucre vanillé"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Mélangez le tout avec un fouet, jusqu'à obtenir une pâte lisse et homogène"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Préparez votre moule ( moule à cake, ou moule à tarte ), en le beurrant bien, pour le démouler facilement après cuisson."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Etalez la pâte dans le moule, et enfournez pendant 30 minutes !"
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Regardez de temps en temps si le gateau est cuit, car selon les fours, la durée est différente. Pour celà, à partir d'une vingtaine de minutes, enfoncez la pointe d'un couteau au milieu de votre gateau au yaourt. Si il ressort sans pâte collée, alors c'est cuit !"
        }
      ]
    }
  ],
