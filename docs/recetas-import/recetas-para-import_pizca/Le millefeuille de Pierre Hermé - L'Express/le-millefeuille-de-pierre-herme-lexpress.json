          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Préchauffez votre four à 230 °C."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Étalez 2 rectangles de pâte feuilletée de 30 x 40 cm. Mettez-les au frais 15 min, puis poudrez-les de sucre semoule."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Enfournez et baissez aussitôt le thermostat à 190 °C."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Au bout de 8 min, couvrez la pâte de papier sulfurisé pour l'empêcher de lever et poursuivez la cuisson 10 min."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Hors du four, poudrez les rectangles de pâte de sucre glace et enfournez de nouveau pour les faire caraméliser. Laissez refroidir."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Faites tremper la gélatine dans de l'eau froide."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Mélangez les jaunes d'oeufs avec le sucre semoule."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Portez à ébullition la crème avec la vanille, laissez infuser."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Versez la crème sur les jaunes et le sucre, fouettez et remettez dans la casserole avant de la cuire comme une crème anglaise. Ajoutez la gélatine égouttée, réservez au frais."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Fouettez le mascarpone et détendez-le progressivement avec la crème anglaise."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Découpez chaque plaque de pâte en 3 bandes puis chaque bande en 3/4 rectangles."
        },
        {
          "cantidad": null,
          "unidad": "QS",
          "ingrediente": "Posez les fruits sur l'un d'eux, recouvrez d'un autre tronçon, puis appliquez la crème au mascarpone avec une poche à douille, et terminez par un rectangle de pâte."
        }
