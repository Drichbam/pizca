    },
    {
      "componente": "Dacquoise",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Préparez le biscuit dacquoise. Hachez finement les pistaches. Mélangez le sucre glace avec les amandes en poudres et les pistaches hachées. Fouettez les blancs d'œufs en neige en y incorporant en 3 fois le sucre en poudre. Assouplissez la pâte de pistache avec un peu de blancs montés.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Incorporez délicatement avec une spatule le mélange sucre glace - amandes et la pâte de pistache. Garnissez-en un poche à douille munie d'une douille lisse nº10",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Préchauffez le four à 170 ºC",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 4,
          "descripcion": "Badigeonnez de beurre un rectangle à pâtisserie de 30x40. Posez-le sur une plaque à pâtisserie recouverte de papier sulfurisé spécial cuisson. Formez des lignes puis le cadre. Saupoudrez de sucre glace. Glissez dans le four et laissez cuire 30 minutes en glissant une cuillère dans la porte du four afin de la maintenir entrouverte. Laissez refroidir sur un grille à pâtisserie.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Crème pâtissière (1/2 serait suffisant)",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Portez à ébullition le lait, la demi-gousse de vanille fendue et grattée de ses graines ainsi que le sucre. Mélangez au fouet la poudre à ﬂan, la farine et les jaunes d'œufs. Ajoutez un tiers du lait chaud en fouettant, puis reversez le tout dans la casserole et portez à ébullition. Mettez à refroidir dans un saladier posé dans un bain-marie d'eau glacée. Enlevez la gousse de vanille. Lorsque la crème a tiédi à 60 °C, incorporez le beurre divisé en morceaux. Collez un film étirable en surface et réservez au réfrigérateur.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Meringue italienne",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Portez à ébullition l'eau minérale avec le sucre et faites cuire jusqu'à 121 °C. Lorsque le mélange atteint 115 °C, commencez à fouetter le blanc d'œuf en neige au « bec d'oiseau ››, c'est-à-dire pas trop ferme. Versez peu à peu en filet le sucre cuit à 121 °C sans cesser de fouetter à vitesse moyenne jusqu'à ce que la meringue soit froide.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Crème au beurre",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Portez à ébullition le lait. Fouttez les jaunes d'œufs avec le sucre (blanchir) et versez un peu de lait bouillant dessus en fouettant vivement, puis remettez à cuire a 85 °C. Faites refroidir la crème dans un bain- marie d'eau glacée, puis mixez au mixeur plongeant. Fouettez le beurre dans le bol d'un robot jusqu'à ce qu'il soit crémeux. incorporez peu à peu la crème refroidie. Retirez le bol du robot, puis incorporez délicatement à la main la meringue italienne. Refroidir au frigo quelques heures.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Crème mousseline pistache",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "=crème au beurre + crème pâtissière + pistache",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Fouettez la crème au beurre 3-4 minutes. Ajoutez la pâte de pistache, puis la crème pâtissière. Mélangez. Garnissez-en une poche munie d'une douille lisse n° 10, puis répartissez la crème sur le fond du biscuit.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Préparez la garniture. Équeutez les fraises. Coupez-les en deux et disposez-les harmonieusement sur la crème. Mélangez la confiture de fraises et nappez-en les fraises. Parsemez de pistaches mondées et concassées.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    }
