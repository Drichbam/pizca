    {
      "componente": "Crème pistache",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Dans une casserole, faites bouillir la crème, verser dessus le chocolat blanc et la pâte de pistaches (j’ai ajouté un peu de colorant vert pour que la crème est une belle couleur pistache). Mixer, mettre en poche et réserver 1 nuit au réfrigérateur.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Dacquoise",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Préparez le biscuit dacquoise. Hachez finement les pistaches. Mélangez le sucre glace avec les amandes en poudres et les pistaches hachées. Fouettez les blancs d'œufs en neige en y incorporant en 3 fois le sucre en poudre. Assouplissez la pâte de pistache avec un peu de blancs montés.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Incorporez délicatement avec une spatule le mélange sucre glace - amandes et la pâte de pistache. Garnissez-en un poche à douille munie d'une douille lisse nº10",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Préchauffez le four à 170 ºC",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 4,
          "descripcion": "Badigeonnez de beurre un cercle à pâtisserie de 24cm de diamètre et de 2 cm de haut, ou un cadre en inox de 20x15. Posez-le sur une plaque à pâtisserie recouverte de papier sulfurisé spécial cuisson. En partant du centre, façonnez une spirale avec la pâte jusqu'au bord du cercle, puis dressez des boules en bordure côte à côte. Dans le cas d'un cadre en inox, tracez des boudins parallèles et ajouter un boudin sur tout le périmètre.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 5,
          "descripcion": "Saupoudrez de sucre glace. Glissez dans le four et laissez cuire 30-40 minutes. Laissez refroidir sur un grille à pâtisserie.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Montage",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Pochez des lignes de crème pistache sur la dacquoise.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Équeutez les fraises. Coupez-les en deux et disposez-les harmonieusement sur la crème. Préparer du nappage neutre (en vente dans le commerce) et nappez-en les fraises pour leur les faire briller. Parsemez de pistaches mondées et concassées.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    }
