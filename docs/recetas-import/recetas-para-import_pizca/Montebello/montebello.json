          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 16,
          "descripcion": "Pipe the batter into the cake mold, until 2 cm height, sprinkle with icing sugar and chopped pistachio nuts, and bake for 30 minutes.",
