    {
      "componente": "Préparation du biscuit pistache",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Dans un saladier, mélanger la poudre de pistache et le sucre glace, les 6 œufs entiers et la pâte de pistache.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Fouetter au batteur à vitesse rapide environ 10 minutes. Ajoutez le beurre fondu et refroidi, petit à petit, en fouettant.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Dans un autre saladier, battez les blancs en neige, en ajoutant progressivement le sucre semoule. Fouettez jusqu'à ce qu'ils soient brillants et très fermes.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 4,
          "descripcion": "Mélangez les 2 préparations en incorporant délicatement les blancs dans la première.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 5,
          "descripcion": "Ajoutez la farine tamisée en pluie puis mélangez délicatement.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 6,
          "descripcion": "Versez la pâte sur une plaque de cuisson tapissée de papier sulfurisé.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 7,
          "descripcion": "Étalez en couche régulière d'1/2 cm environ.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 8,
          "descripcion": "Faites cuire au four environ 10 minutes à 200ºC",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 9,
          "descripcion": "La pâte est cuite lorsqu'elle est juste ferme et ne colle plus au doigt.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 10,
          "descripcion": "Laissez refroidir sur un grille, puis découpez à l'emporte-pièce.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    },
    {
      "componente": "Préparation de la crème au mascarpone",
      "pasos": [
        {
          "orden": 1,
          "descripcion": "Séparez les blancs des jaunes. Blanchir les jaunes avec les 200g sucre glace jusqu'à ce que le mélange forme un ruban.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 2,
          "descripcion": "Ajoutez le mascarpone en petits morceaux et la pâte de pistache. Mélangez.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 3,
          "descripcion": "Fouettez les blancs en neige ferme avec 30g de sucre.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 4,
          "descripcion": "Incorporez au mélange précédent et mettez au frais.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
