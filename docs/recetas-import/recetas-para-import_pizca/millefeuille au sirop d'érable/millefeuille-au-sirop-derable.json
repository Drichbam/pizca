        },
        {
          "orden": 8,
          "descripcion": "250 gr de sirop d'érable",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 9,
          "descripcion": "190 gr de crème fluide à 30% de MG",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 10,
          "descripcion": "Etape 1 : Cuisson de la pâte",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 11,
          "descripcion": "1. Etaler la pâte sur 2 mm d'épaisseur à l'aide d'un rouleau sur un plan de travail légèrement fariné et piquer-la légèrement",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 12,
          "descripcion": "2. Réaliser un joli rectangle puis dresser la pâte sur une plaque entre deux feuilles de papier cuisson et poser une deuxième plaque de cuisson (pas trop lourde) dessus",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 13,
          "descripcion": "3. Faire cuire à 180° environ 30 mn : il faut que la pâte soit de couleur brun caramel",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 14,
          "descripcion": "Etape 2 : Réaliser la crème légère au sirop d'érable",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 15,
          "descripcion": "1. Faire réduire 250 gr de sirop d'érable pour en obtenir 170 gr",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 16,
          "descripcion": "2. Faire tremper la gélatine dans de l'eau froide",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 17,
          "descripcion": "3. Dans une casserole mélanger puis cuire à 85° 120 gr de sirop d'érable réduit, 190 gr de crème fluide à 30%, 3 jaunes d'œufs (soit 60 gr) et la gélatine préalablement essorée.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 18,
          "descripcion": "4. Dès que la crème est cuite, retirer-la du feu, incorporer le mascarpone et mixer une bonne minute à l'aide d'un mixeur plongeant",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 19,
          "descripcion": "5. Filmer pour éviter qu'une croute se forme et réserver-la 24 heures au réfrigérateur.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 20,
          "descripcion": "Etape 3 : Caraméliser la pâte",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 21,
          "descripcion": "1. Poser une plaque bien droite sur le feuilletage pour le tasser légèrement, retourner le tout et saupoudrer de sucre glace (100 gr environ)",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 22,
          "descripcion": "2. Mettre sous le grill du four quelques minutes pour caraméliser le sucre",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 23,
          "descripcion": "3. Retirer du four, attendre quelques minutes et couper trois bandes rectangulaires",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 24,
          "descripcion": "4. Laisser refroidir à température ambiante",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 25,
          "descripcion": "Etape 4 : Dressage et finitions",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 26,
          "descripcion": "1. Monter la crème au sirop d'érable au fouet électrique au minimum 5 mn",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 27,
          "descripcion": "2. Dresser la crème dans une poche sans douille,",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 28,
          "descripcion": "3. Dresser 3 boudins de crème sur un rectangle de feuilletage caramélisé (face caramélisée en dessous) et ajouter du sirop d'érable réduit. Poser un autre rectangle de feuilletage et renouveler l'opération. Fermer avec le 3ème rectangle de feuilletage.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 29,
          "descripcion": "4. Poser le millefeuille sur la tranche",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 30,
          "descripcion": "5. Dresser la crème avec une poche munie d'une douille st Honoré sur la surface.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 31,
          "descripcion": "6. Déguster sans attendre !!!",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        },
        {
          "orden": 32,
          "descripcion": "Vous pouvez ajouter du sucre d'érable ou du pralin lorsque vous dressez votre millefeuille sur chaque couche de crème.",
          "temp_c": null,
          "duracion_min": null,
          "notas_tecnicas": null
        }
      ]
    }
